import numpy as np

def calculate_pagerank(M, d=0.85):
    n = len(M)
    v = np.ones(n) / n
    # Normalizimi i matricës
    M_norm = M / np.where(M.sum(axis=1)[:, None] == 0, 1, M.sum(axis=1)[:, None])
    for _ in range(50): 
        v = (1 - d) / n + d * (M_norm.T @ v)
    return v

